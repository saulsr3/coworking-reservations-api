{
  "info": {
    "name": "Coworking Reservations API",
    "description": "Prueba técnica Banco Cuscatlán / Tribu Digital — microservicio de gestión de reservas de espacios de coworking.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Saul Reyes\",\n  \"email\": \"saul@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set(\"token\", response.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"saul@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set(\"token\", response.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users (ADMIN)",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const users = pm.response.json();",
                  "    if (users.length > 0) { pm.environment.set(\"userId\", users[0].id); }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update User Role (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"ADMIN\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}/role", "host": ["{{baseUrl}}"], "path": ["api", "users", "{{userId}}", "role"] }
          }
        }
      ]
    },
    {
      "name": "Spaces",
      "item": [
        {
          "name": "Create Space (ADMIN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sala Reuniones A\",\n  \"type\": \"MEETING_ROOM\",\n  \"capacity\": 8,\n  \"location\": \"Piso 2\",\n  \"hourlyRate\": 15.00\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/spaces", "host": ["{{baseUrl}}"], "path": ["api", "spaces"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set(\"spaceId\", response.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Spaces (filtros opcionales)",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": {
              "raw": "{{baseUrl}}/api/spaces?type=MEETING_ROOM&minCapacity=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "spaces"],
              "query": [
                { "key": "type", "value": "MEETING_ROOM" },
                { "key": "minCapacity", "value": "1" },
                { "key": "location", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Space by Id",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/api/spaces/{{spaceId}}", "host": ["{{baseUrl}}"], "path": ["api", "spaces", "{{spaceId}}"] }
          }
        },
        {
          "name": "Update Space (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sala Reuniones A - Renovada\",\n  \"type\": \"MEETING_ROOM\",\n  \"capacity\": 10,\n  \"location\": \"Piso 2\",\n  \"hourlyRate\": 18.00\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/spaces/{{spaceId}}", "host": ["{{baseUrl}}"], "path": ["api", "spaces", "{{spaceId}}"] }
          }
        },
        {
          "name": "Delete Space (ADMIN)",
          "request": {
            "method": "DELETE",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/api/spaces/{{spaceId}}", "host": ["{{baseUrl}}"], "path": ["api", "spaces", "{{spaceId}}"] }
          }
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "Create Reservation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"spaceId\": {{spaceId}},\n  \"startTime\": \"2026-07-25T10:00:00\",\n  \"endTime\": \"2026-07-25T12:00:00\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/reservations", "host": ["{{baseUrl}}"], "path": ["api", "reservations"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set(\"reservationId\", response.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Reservation (solapada - debe dar 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"spaceId\": {{spaceId}},\n  \"startTime\": \"2026-07-25T11:00:00\",\n  \"endTime\": \"2026-07-25T13:00:00\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/reservations", "host": ["{{baseUrl}}"], "path": ["api", "reservations"] }
          }
        },
        {
          "name": "My Reservations",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/api/reservations/me", "host": ["{{baseUrl}}"], "path": ["api", "reservations", "me"] }
          }
        },
        {
          "name": "All Reservations (ADMIN)",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/api/reservations/admin/all", "host": ["{{baseUrl}}"], "path": ["api", "reservations", "admin", "all"] }
          }
        },
        {
          "name": "Cancel Reservation",
          "request": {
            "method": "DELETE",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/api/reservations/{{reservationId}}", "host": ["{{baseUrl}}"], "path": ["api", "reservations", "{{reservationId}}"] }
          }
        }
      ]
    },
    {
      "name": "Reports",
